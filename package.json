{
  "name": "cxg-workflow",
  "version": "0.1.5",
  "description": "Codex CLI single-model workflow system - structured development workflow powered by Codex",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "author": {
    "name": "CXG Contributors"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cainsyake/cxg-workflow"
  },
  "homepage": "https://github.com/cainsyake/cxg-workflow",
  "bugs": {
    "url": "https://github.com/cainsyake/cxg-workflow/issues"
  },
  "keywords": [
    "codex",
    "ai",
    "cli",
    "workflow",
    "single-model"
  ],
  "bin": {
    "cxg": "bin/cxg.mjs"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/cxg.mjs",
    "dist",
    "templates/skills/",
    "templates/roles/"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "unbuild",
    "start": "node bin/cxg.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "ansis": "^4.1.0",
    "cac": "^6.7.14",
    "fs-extra": "^11.3.2",
    "inquirer": "^12.9.6",
    "pathe": "^2.0.3",
    "smol-toml": "^1.4.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.36.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "unbuild": "^3.6.1",
    "vitest": "^3.1.1"
  }
}
